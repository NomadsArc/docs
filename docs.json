{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Slice 'n Save",
  "theme": "luma",
  "colors": {
    "primary": "#7b7c7c",
    "light": "#c1c1c1",
    "dark": "#060606"
  },
  "favicon": "https://media.brand.dev/5db8a070-f10c-4850-ba79-c55dbaf627eb.png",
  "navigation": {
    "products": [
      {
        "product": "Slice 'n Save",
        "languages": [
          {
            "language": "en",
            "default": true,
            "tabs": [
              {
                "tab": "Documentation",
                "groups": [
                  {
                    "group": "Get Started",
                    "expanded": true,
                    "pages": [
                      "introduction",
                      "overview/features",
                      "overview/getting-started",
                      "overview/limitations"
                    ]
                  },
                  {
                    "group": "Discount Types",
                    "pages": [
                      "use-cases/amount-off-products",
                      "use-cases/amount-off-order",
                      "use-cases/free-shipping",
                      "use-cases/amount-off-shipping-rate",
                      "use-cases/bogo-buy-x-get-y",
                      "use-cases/tiered-discounts",
                      "use-cases/quantity-breaks"
                    ]
                  }
                ],
                "hidden": true
              }
            ]
          }
        ]
      },
      {
        "product": "Dynamic Checkout Customizer"
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Install App",
      "href": "https://apps.shopify.com/slice-n-save"
    }
  },
  "logo": {
    "light": "/images/slice-n-save-easy.png",
    "dark": "/images/slice-n-save-easy.png"
  }
}
